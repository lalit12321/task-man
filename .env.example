# MongoDB connection string. For local dev you can use MongoDB Atlas (free tier)
# or a local mongod instance. The driver supports both mongodb:// and mongodb+srv://
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Database name. Will be created automatically on first write.
MONGODB_DB=teamflow

# JWT signing secret. Generate a strong random string for production.
# On Linux/Mac:  openssl rand -base64 48
# On Windows PowerShell:  [Convert]::ToBase64String((1..48 | %{[byte](Get-Random -Max 256)}))
JWT_SECRET=replace-this-with-a-long-random-string-at-least-32-chars

# Railway sets PORT automatically. Locally we default to 3000.
# PORT=3000
